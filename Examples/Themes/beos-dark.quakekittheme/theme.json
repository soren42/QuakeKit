{
  "$schema": "../../schemas/theme-plugin.schema.json",
  "id": "beos_dark",
  "name": "BeOS Dark",
  "version": "1.0.0-rc1",
  "apiVersion": "0.1",
  "kind": "theme",
  "author": "QuakeKit",
  "description": "BeOS Dark RC1 theme imported from the Claude Design token contract.",
  "palette": {
    "mode": "dark",
    "colors": {
      "background": {
        "value": "#191919",
        "role": "Base panel background",
        "configurable": false
      },
      "surface": {
        "value": "#292929",
        "role": "Tile and row background",
        "configurable": false
      },
      "surfaceRaised": {
        "value": "#3A3A3A",
        "role": "Selected and raised surfaces",
        "configurable": false
      },
      "border": {
        "value": "#757575",
        "role": "Subtle separators",
        "configurable": false
      },
      "textPrimary": {
        "value": "#F4F4F4",
        "role": "Primary text",
        "configurable": false
      },
      "textSecondary": {
        "value": "#C0C0C0",
        "role": "Secondary text",
        "configurable": false
      },
      "accent": {
        "value": "#FFD648",
        "role": "Focus and positive highlight",
        "configurable": true
      },
      "success": {
        "value": "#70C070",
        "role": "Healthy state",
        "configurable": true
      },
      "warning": {
        "value": "#FFAF38",
        "role": "Attention state",
        "configurable": true
      },
      "danger": {
        "value": "#FF6B5C",
        "role": "Error state",
        "configurable": true
      }
    },
    "semanticColors": {
      "background": "background",
      "surface": "surface",
      "surfaceRaised": "surfaceRaised",
      "border": "border",
      "textPrimary": "textPrimary",
      "textSecondary": "textSecondary",
      "accent": "accent",
      "success": "success",
      "warning": "warning",
      "danger": "danger"
    }
  },
  "typography": {
    "displayFont": "SF Pro",
    "bodyFont": "SF Pro",
    "monoFont": "SF Mono",
    "scale": {
      "caption": 13,
      "body": 16,
      "title": 24,
      "value": 32
    }
  },
  "metrics": {
    "cornerRadius": 2,
    "borderWidth": 1,
    "spacing": 10,
    "density": "standard"
  },
  "layout": {
    "defaultPageStyle": "grid",
    "widgetGrid": {
      "columns": 4,
      "rows": 2
    },
    "appletGrid": {
      "columns": 2,
      "rows": 1
    },
    "splitRatio": 0.5
  },
  "components": {
    "tile": {
      "background": "surface",
      "foreground": "textPrimary",
      "border": "border",
      "accent": "accent",
      "selectedBackground": "surfaceRaised",
      "selectedBorder": "accent"
    },
    "tab": {
      "background": "surface",
      "foreground": "textPrimary",
      "border": "border",
      "selectedBackground": "surfaceRaised",
      "selectedBorder": "accent"
    },
    "statusRow": {
      "background": "surface",
      "foreground": "textPrimary",
      "border": "border",
      "accent": "accent"
    },
    "gauge": {
      "background": "surface",
      "foreground": "textPrimary",
      "accent": "accent"
    },
    "chart": {
      "background": "surface",
      "foreground": "textPrimary",
      "accent": "accent"
    }
  },
  "hardware": {
    "knobRing": {
      "enabled": true,
      "idle": {
        "color": "accent",
        "intensity": 0.2,
        "animation": "solid"
      },
      "focus": {
        "color": "accent",
        "intensity": 0.7,
        "animation": "pulse"
      },
      "success": {
        "color": "success",
        "intensity": 0.8,
        "animation": "solid"
      },
      "warning": {
        "color": "warning",
        "intensity": 0.85,
        "animation": "pulse"
      },
      "danger": {
        "color": "danger",
        "intensity": 1,
        "animation": "flash"
      },
      "progress": {
        "color": "accent",
        "intensity": 0.75,
        "animation": "progress"
      }
    }
  },
  "assets": [],
  "options": [
    {
      "id": "accentColor",
      "title": "Accent color",
      "type": "color",
      "target": "palette.colors.accent.value",
      "defaultValue": "#FFD648"
    },
    {
      "id": "successColor",
      "title": "Success color",
      "type": "color",
      "target": "palette.colors.success.value",
      "defaultValue": "#6CFF8F"
    },
    {
      "id": "warningColor",
      "title": "Warning color",
      "type": "color",
      "target": "palette.colors.warning.value",
      "defaultValue": "#FFD166"
    },
    {
      "id": "dangerColor",
      "title": "Danger color",
      "type": "color",
      "target": "palette.colors.danger.value",
      "defaultValue": "#FF5C7A"
    },
    {
      "id": "cornerRadius",
      "title": "Corner radius",
      "type": "number",
      "target": "metrics.cornerRadius",
      "defaultValue": 8,
      "minimum": 2,
      "maximum": 16
    },
    {
      "id": "spacing",
      "title": "Spacing",
      "type": "number",
      "target": "metrics.spacing",
      "defaultValue": 10,
      "minimum": 6,
      "maximum": 16
    },
    {
      "id": "density",
      "title": "Density",
      "type": "choice",
      "target": "metrics.density",
      "defaultValue": "standard",
      "choices": [
        "compact",
        "standard",
        "comfortable"
      ]
    }
  ]
}
