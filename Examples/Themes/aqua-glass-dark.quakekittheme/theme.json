{
  "$schema": "../../schemas/theme-plugin.schema.json",
  "id": "aqua_glass_dark",
  "name": "Aqua Glass Dark",
  "version": "1.0.0-rc1",
  "apiVersion": "0.1",
  "kind": "theme",
  "author": "QuakeKit",
  "description": "Aqua Glass Dark RC1 theme imported from the Claude Design token contract.",
  "palette": {
    "mode": "dark",
    "colors": {
      "background": {
        "value": "#08111F",
        "role": "Night sky background",
        "configurable": false
      },
      "surface": {
        "value": "#16233BE6",
        "role": "Translucent glass surface",
        "configurable": true
      },
      "surfaceRaised": {
        "value": "#243555F2",
        "role": "Raised glass surface",
        "configurable": true
      },
      "border": {
        "value": "#6A8FC766",
        "role": "Glass rim",
        "configurable": true
      },
      "textPrimary": {
        "value": "#F7FBFF",
        "role": "Primary text",
        "configurable": false
      },
      "textSecondary": {
        "value": "#BED1E8",
        "role": "Secondary text",
        "configurable": false
      },
      "accent": {
        "value": "#0A84FF",
        "role": "Weather highlight",
        "configurable": true
      },
      "success": {
        "value": "#64D2FF",
        "role": "Favorable state",
        "configurable": true
      },
      "warning": {
        "value": "#FF9F0A",
        "role": "Watch state",
        "configurable": true
      },
      "danger": {
        "value": "#FF453A",
        "role": "Alert state",
        "configurable": true
      }
    },
    "semanticColors": {
      "background": "background",
      "surface": "surface",
      "surfaceRaised": "surfaceRaised",
      "border": "border",
      "textPrimary": "textPrimary",
      "textSecondary": "textSecondary",
      "accent": "accent",
      "success": "success",
      "warning": "warning",
      "danger": "danger"
    }
  },
  "typography": {
    "displayFont": "SF Pro Rounded",
    "bodyFont": "SF Pro",
    "monoFont": "SF Mono",
    "scale": {
      "caption": 13,
      "body": 16,
      "title": 26,
      "value": 42
    }
  },
  "metrics": {
    "cornerRadius": 13,
    "borderWidth": 1,
    "spacing": 12,
    "density": "comfortable"
  },
  "components": {
    "tile": {
      "background": "surface",
      "foreground": "textPrimary",
      "border": "border",
      "accent": "accent",
      "selectedBackground": "surfaceRaised",
      "selectedBorder": "accent"
    },
    "tab": {
      "background": "surface",
      "foreground": "textPrimary",
      "border": "border",
      "selectedBackground": "surfaceRaised",
      "selectedBorder": "accent"
    },
    "statusRow": {
      "background": "surface",
      "foreground": "textPrimary",
      "border": "border",
      "accent": "accent"
    },
    "gauge": {
      "background": "surface",
      "foreground": "textPrimary",
      "accent": "accent"
    },
    "chart": {
      "background": "surface",
      "foreground": "textPrimary",
      "accent": "accent"
    }
  },
  "hardware": {
    "knobRing": {
      "enabled": true,
      "idle": {
        "color": "border",
        "intensity": 0.18,
        "animation": "solid"
      },
      "focus": {
        "color": "accent",
        "intensity": 0.65,
        "animation": "pulse"
      },
      "success": {
        "color": "success",
        "intensity": 0.75,
        "animation": "solid"
      },
      "warning": {
        "color": "warning",
        "intensity": 0.85,
        "animation": "pulse"
      },
      "danger": {
        "color": "danger",
        "intensity": 1,
        "animation": "flash"
      },
      "progress": {
        "color": "accent",
        "intensity": 0.7,
        "animation": "progress"
      }
    }
  },
  "layout": {
    "defaultPageStyle": "thirds",
    "widgetGrid": {
      "columns": 3,
      "rows": 2
    },
    "appletGrid": {
      "columns": 3,
      "rows": 1
    },
    "splitRatio": 0.34
  },
  "assets": [],
  "options": [
    {
      "id": "accentColor",
      "title": "Accent color",
      "type": "color",
      "target": "palette.colors.accent.value",
      "defaultValue": "#0A84FF"
    },
    {
      "id": "cornerRadius",
      "title": "Corner radius",
      "type": "number",
      "target": "metrics.cornerRadius",
      "defaultValue": 8,
      "minimum": 2,
      "maximum": 16
    },
    {
      "id": "spacing",
      "title": "Spacing",
      "type": "number",
      "target": "metrics.spacing",
      "defaultValue": 12,
      "minimum": 8,
      "maximum": 18
    },
    {
      "id": "density",
      "title": "Density",
      "type": "choice",
      "target": "metrics.density",
      "defaultValue": "comfortable",
      "choices": [
        "compact",
        "standard",
        "comfortable"
      ]
    }
  ]
}
