{
  "$schema": "../../../schemas/functional-plugin.schema.json",
  "id": "chatgpt_harness",
  "name": "ChatGPT Harness",
  "version": "0.1.0",
  "apiVersion": "0.1",
  "entry": { "transport": "shell", "command": "chatgpt-harness.sh", "arguments": [] },
  "capabilities": ["dataProvider", "settings", "viewProvider", "actionProvider"],
  "permissions": [
    { "network": { "hosts": ["api.openai.com"] } },
    { "secrets": { "keys": ["OPENAI_API_KEY"] } }
  ],
  "settings": [
    { "id": "model", "title": "Model", "type": "choice", "defaultValue": "gpt-4.1", "choices": ["gpt-4.1", "gpt-4.1-mini", "o4-mini"], "environment": "QUAKEKIT_OPENAI_MODEL", "help": "OpenAI API model alias." },
    { "id": "mode", "title": "Mode", "type": "choice", "defaultValue": "assistant", "choices": ["assistant", "voice", "meeting_summary", "coding"], "environment": "QUAKEKIT_OPENAI_MODE", "help": "Prompt/workflow preset." }
  ],
  "actions": [
    { "id": "chatgpt.refresh", "title": "Refresh ChatGPT", "argumentSchema": [] },
    { "id": "chatgpt.sendPrompt", "title": "Send Prompt", "argumentSchema": [] }
  ],
  "dataStreams": [{ "id": "chatgpt.session", "title": "ChatGPT Session", "valueSchema": [] }],
  "views": [
    { "id": "chatgpt.panel", "title": "ChatGPT", "type": "dataDriven", "presentation": "pageAndWidget", "dataStreamID": "chatgpt.session", "columnSpan": 2, "rowSpan": 1, "preferredWidth": 640, "preferredHeight": 240 }
  ]
}
