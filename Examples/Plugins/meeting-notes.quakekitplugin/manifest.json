{
  "$schema": "../../../schemas/functional-plugin.schema.json",
  "id": "meeting_notes",
  "name": "Meeting Notes",
  "version": "0.1.0",
  "apiVersion": "0.1",
  "entry": {
    "transport": "shell",
    "command": "meeting-notes.sh",
    "arguments": []
  },
  "capabilities": [
    "dataProvider",
    "settings",
    "viewProvider",
    "actionProvider",
    "backgroundWorker"
  ],
  "permissions": [
    {
      "audioCapture": {}
    },
    {
      "audioPlayback": {}
    },
    {
      "localProcess": {}
    },
    {
      "filesystem": {
        "paths": [
          "~/Documents",
          "~/Desktop",
          "~/Downloads"
        ],
        "write": true
      }
    },
    {
      "network": {
        "hosts": [
          "api.openai.com",
          "api.anthropic.com",
          "generativelanguage.googleapis.com"
        ]
      }
    },
    {
      "secrets": {
        "keys": [
          "OPENAI_API_KEY",
          "ANTHROPIC_API_KEY",
          "GEMINI_API_KEY"
        ]
      }
    }
  ],
  "settings": [
    {
      "id": "capture_mode",
      "title": "Capture Mode",
      "type": "choice",
      "defaultValue": "audio_file",
      "choices": [
        "audio_file",
        "live_microphone_stub",
        "wispr_flow"
      ],
      "environment": "QUAKEKIT_MEETING_CAPTURE_MODE",
      "help": "Audio capture source. Live microphone recording is declared but not enabled until the host owns recording."
    },
    {
      "id": "audio_file",
      "title": "Audio File",
      "type": "string",
      "defaultValue": "",
      "environment": "QUAKEKIT_MEETING_AUDIO_FILE",
      "help": "Optional local audio file to transcribe using a configured backend."
    },
    {
      "id": "transcription_backend",
      "title": "Transcription Backend",
      "type": "choice",
      "defaultValue": "whisper_cli",
      "choices": [
        "whisper_cli",
        "wispr_flow",
        "apple_speech",
        "openai_whisper"
      ],
      "environment": "QUAKEKIT_MEETING_TRANSCRIBE_BACKEND",
      "help": "Preferred speech-to-text backend."
    },
    {
      "id": "summary_format",
      "title": "Summary Format",
      "type": "choice",
      "defaultValue": "action_items",
      "choices": [
        "action_items",
        "meeting_minutes",
        "brainstorm",
        "decision_log"
      ],
      "environment": "QUAKEKIT_MEETING_SUMMARY_FORMAT",
      "help": "Output format for summarization."
    }
  ],
  "actions": [
    {
      "id": "meeting.record",
      "title": "Record",
      "argumentSchema": []
    },
    {
      "id": "meeting.transcribe",
      "title": "Transcribe",
      "argumentSchema": []
    },
    {
      "id": "meeting.summarize",
      "title": "Summarize",
      "argumentSchema": []
    },
    {
      "id": "meeting.export",
      "title": "Export Notes",
      "argumentSchema": []
    }
  ],
  "dataStreams": [
    {
      "id": "meeting.summary",
      "title": "Meeting Summary",
      "valueSchema": [
        {
          "id": "meetingTitle",
          "title": "Meeting Title",
          "type": "string",
          "required": false
        },
        {
          "id": "durationMinutes",
          "title": "Duration Minutes",
          "type": "integer",
          "required": false
        },
        {
          "id": "captureMode",
          "title": "Capture Mode",
          "type": "string",
          "required": false
        },
        {
          "id": "transcriptPreview",
          "title": "Transcript Preview",
          "type": "string",
          "required": false
        },
        {
          "id": "summaryFormat",
          "title": "Summary Format",
          "type": "string",
          "required": false
        }
      ]
    }
  ],
  "views": [
    {
      "id": "meeting.panel",
      "title": "Meeting Notes",
      "type": "dataDriven",
      "presentation": "pageAndWidget",
      "dataStreamID": "meeting.summary",
      "columnSpan": 3,
      "rowSpan": 1,
      "preferredWidth": 960,
      "preferredHeight": 240,
      "icon": "mic"
    }
  ]
}
