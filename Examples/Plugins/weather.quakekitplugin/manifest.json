{
  "$schema": "../../../schemas/functional-plugin.schema.json",
  "id": "weather",
  "name": "Weather",
  "version": "0.1.0",
  "apiVersion": "0.1",
  "entry": {
    "transport": "shell",
    "command": "weather.sh",
    "arguments": []
  },
  "capabilities": [
    "dataProvider",
    "settings",
    "viewProvider"
  ],
  "permissions": [
    {
      "network": {
        "hosts": [
          "api.weather.gov",
          "api.open-meteo.com"
        ]
      }
    }
  ],
  "settings": [
    {
      "id": "location",
      "title": "Location",
      "type": "choice",
      "defaultValue": "Charlotte, NC",
      "choices": [
        "Charlotte, NC",
        "Raleigh, NC",
        "New York, NY",
        "San Francisco, CA",
        "Custom"
      ],
      "environment": "QUAKEKIT_WEATHER_LOCATION",
      "help": "Preset city used by the weather data provider."
    },
    {
      "id": "units",
      "title": "Units",
      "type": "choice",
      "defaultValue": "fahrenheit",
      "choices": [
        "fahrenheit",
        "celsius"
      ],
      "environment": "QUAKEKIT_WEATHER_UNITS",
      "help": "Temperature unit requested from Open-Meteo."
    }
  ],
  "actions": [
    {
      "id": "weather.refresh",
      "title": "Refresh Forecast",
      "argumentSchema": []
    }
  ],
  "dataStreams": [
    {
      "id": "weather.current",
      "title": "Current Weather",
      "valueSchema": []
    }
  ],
  "views": [
    {
      "id": "weather.canvas",
      "title": "Weather Canvas",
      "type": "webCanvas",
      "presentation": "pageAndWidget",
      "entryPath": "index.html",
      "dataStreamID": "weather.current",
      "columnSpan": 2,
      "rowSpan": 1,
      "preferredWidth": 480,
      "preferredHeight": 200
    }
  ]
}
