{
  "id": "weather",
  "name": "Weather",
  "version": "0.1.0",
  "apiVersion": "0.1",
  "entry": {
    "transport": "webView",
    "command": null,
    "arguments": [],
    "url": "index.html"
  },
  "capabilities": [
    "dataProvider",
    "viewProvider"
  ],
  "permissions": [
    {
      "network": {
        "hosts": [
          "api.weather.gov",
          "api.open-meteo.com"
        ]
      }
    }
  ],
  "actions": [
    {
      "id": "weather.refresh",
      "title": "Refresh Forecast",
      "argumentSchema": []
    }
  ],
  "dataStreams": [
    {
      "id": "weather.current",
      "title": "Current Weather",
      "valueSchema": []
    }
  ],
  "views": [
    {
      "id": "weather.canvas",
      "title": "Weather Canvas",
      "type": "webCanvas",
      "presentation": "pageAndWidget",
      "entryPath": "index.html",
      "dataStreamID": "weather.current",
      "columnSpan": 2,
      "rowSpan": 1,
      "preferredWidth": 480,
      "preferredHeight": 200
    }
  ]
}
