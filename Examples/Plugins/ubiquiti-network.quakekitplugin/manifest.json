{
  "$schema": "../../../schemas/functional-plugin.schema.json",
  "id": "ubiquiti_network",
  "name": "Ubiquiti Network",
  "version": "0.1.0",
  "apiVersion": "0.1",
  "entry": {
    "transport": "shell",
    "command": "ubiquiti-network.sh",
    "arguments": []
  },
  "capabilities": [
    "actionProvider",
    "dataProvider",
    "settings",
    "viewProvider",
    "deviceProvider"
  ],
  "permissions": [
    {
      "network": {
        "hosts": [
          "unifi.local",
          "localhost"
        ]
      }
    },
    {
      "secrets": {
        "keys": [
          "UNIFI_API_TOKEN"
        ]
      }
    }
  ],
  "settings": [
    {
      "id": "controller_url",
      "title": "Controller URL",
      "type": "string",
      "defaultValue": "https://unifi.local",
      "environment": "QUAKEKIT_UNIFI_CONTROLLER_URL",
      "help": "UniFi Network controller URL used by real adapters.",
      "group": "Connection",
      "order": 10,
      "uiControl": "textField"
    },
    {
      "id": "site",
      "title": "Site",
      "type": "string",
      "defaultValue": "default",
      "environment": "QUAKEKIT_UNIFI_SITE",
      "help": "UniFi site name summarized by the panel.",
      "group": "Connection",
      "order": 20,
      "uiControl": "textField"
    },
    {
      "id": "client_filter",
      "title": "Client Filter",
      "type": "choice",
      "defaultValue": "all",
      "choices": [
        "all",
        "wired",
        "wireless"
      ],
      "environment": "QUAKEKIT_UNIFI_CLIENT_FILTER",
      "help": "Client group highlighted in the deterministic response.",
      "group": "Network",
      "order": 30,
      "uiControl": "segmented"
    },
    {
      "id": "security_mode",
      "title": "Security Mode",
      "type": "choice",
      "defaultValue": "home",
      "choices": [
        "home",
        "away",
        "night",
        "privacy"
      ],
      "environment": "QUAKEKIT_UNIFI_SECURITY_MODE",
      "help": "Protect camera/security mode represented by the widget.",
      "group": "Security",
      "order": 40,
      "uiControl": "segmented"
    },
    {
      "id": "camera_group",
      "title": "Camera Group",
      "type": "choice",
      "defaultValue": "perimeter",
      "choices": [
        "perimeter",
        "interior",
        "all"
      ],
      "environment": "QUAKEKIT_UNIFI_CAMERA_GROUP",
      "help": "Camera group summarized in the security card.",
      "group": "Security",
      "order": 50,
      "uiControl": "popup"
    },
    {
      "id": "dry_run",
      "title": "Dry Run",
      "type": "boolean",
      "defaultValue": true,
      "environment": "QUAKEKIT_UNIFI_DRY_RUN",
      "help": "When true, network and security actions return request plans only.",
      "group": "Safety",
      "order": 60,
      "uiControl": "toggle"
    }
  ],
  "actions": [
    {
      "id": "unifi.refresh",
      "title": "Refresh UniFi",
      "argumentSchema": []
    },
    {
      "id": "unifi.restartAccessPoint",
      "title": "Restart Access Point",
      "argumentSchema": [
        {
          "id": "device_id",
          "title": "Device ID",
          "type": "string",
          "required": false
        }
      ]
    },
    {
      "id": "unifi.blockClient",
      "title": "Block Client",
      "argumentSchema": [
        {
          "id": "client_id",
          "title": "Client ID",
          "type": "string",
          "required": false
        }
      ]
    },
    {
      "id": "unifi.setProtectMode",
      "title": "Set Protect Mode",
      "argumentSchema": [
        {
          "id": "mode",
          "title": "Mode",
          "type": "string",
          "required": false,
          "defaultValue": "home"
        }
      ]
    },
    {
      "id": "unifi.openCamera",
      "title": "Open Camera",
      "argumentSchema": [
        {
          "id": "camera_id",
          "title": "Camera ID",
          "type": "string",
          "required": false,
          "defaultValue": "driveway"
        }
      ]
    }
  ],
  "dataStreams": [
    {
      "id": "unifi.health",
      "title": "Network Health",
      "valueSchema": [
        {
          "id": "wanStatus",
          "title": "WAN Status",
          "type": "string",
          "required": false
        },
        {
          "id": "clients",
          "title": "Clients",
          "type": "integer",
          "required": false
        },
        {
          "id": "uptimePercent",
          "title": "Uptime Percent",
          "type": "number",
          "required": false
        },
        {
          "id": "securityMode",
          "title": "Security Mode",
          "type": "string",
          "required": false
        },
        {
          "id": "cameraAlerts",
          "title": "Camera Alerts",
          "type": "integer",
          "required": false
        }
      ]
    }
  ],
  "views": [
    {
      "id": "unifi.overview",
      "title": "Network Overview",
      "type": "dataDriven",
      "presentation": "pageAndWidget",
      "layout": "grid",
      "dataStreamID": "unifi.health",
      "columnSpan": 2,
      "rowSpan": 2,
      "preferredWidth": 560,
      "preferredHeight": 360
    }
  ]
}
