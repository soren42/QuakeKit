{
  "$schema": "../../../schemas/functional-plugin.schema.json",
  "id": "discord_companion",
  "name": "Discord Companion",
  "version": "0.1.0",
  "apiVersion": "0.1",
  "entry": {
    "transport": "shell",
    "command": "discord-companion.sh",
    "arguments": []
  },
  "capabilities": [
    "actionProvider",
    "dataProvider",
    "settings",
    "viewProvider"
  ],
  "permissions": [
    {
      "network": {
        "hosts": [
          "discord.com"
        ]
      }
    },
    {
      "secrets": {
        "keys": [
          "DISCORD_BOT_TOKEN",
          "DISCORD_WEBHOOK_URL"
        ]
      }
    }
  ],
  "settings": [
    {
      "id": "guild_id",
      "title": "Guild ID",
      "type": "string",
      "defaultValue": "example-guild",
      "environment": "QUAKEKIT_DISCORD_GUILD_ID",
      "help": "Discord guild identifier used by real adapters.",
      "group": "Connection",
      "order": 10,
      "uiControl": "textField"
    },
    {
      "id": "status_channel",
      "title": "Status Channel",
      "type": "string",
      "defaultValue": "stream-room",
      "environment": "QUAKEKIT_DISCORD_STATUS_CHANNEL",
      "help": "Channel name displayed by the companion panel.",
      "group": "Connection",
      "order": 20,
      "uiControl": "textField"
    },
    {
      "id": "presence_mode",
      "title": "Presence Mode",
      "type": "choice",
      "defaultValue": "available",
      "choices": [
        "available",
        "idle",
        "do_not_disturb"
      ],
      "environment": "QUAKEKIT_DISCORD_PRESENCE_MODE",
      "help": "Presence state that would be announced by an authenticated adapter.",
      "group": "Presence",
      "order": 30,
      "uiControl": "segmented"
    },
    {
      "id": "activity_template",
      "title": "Activity Template",
      "type": "choice",
      "defaultValue": "streaming",
      "choices": [
        "streaming",
        "coding",
        "meeting",
        "offline"
      ],
      "environment": "QUAKEKIT_DISCORD_ACTIVITY_TEMPLATE",
      "help": "Deterministic activity card used when no bot token is configured.",
      "group": "Presence",
      "order": 40,
      "uiControl": "popup"
    },
    {
      "id": "stream_title",
      "title": "Stream Title",
      "type": "string",
      "defaultValue": "Working session",
      "environment": "QUAKEKIT_DISCORD_STREAM_TITLE",
      "help": "Title used by stream helper status and announcement plans.",
      "group": "Stream",
      "order": 45,
      "uiControl": "textField"
    },
    {
      "id": "go_live_url",
      "title": "Go Live URL",
      "type": "string",
      "defaultValue": "",
      "environment": "QUAKEKIT_DISCORD_GO_LIVE_URL",
      "help": "Optional stream URL included in dry-run announcement payloads.",
      "group": "Stream",
      "order": 46,
      "uiControl": "textField"
    },
    {
      "id": "mention_role",
      "title": "Mention Role",
      "type": "string",
      "defaultValue": "@stream",
      "environment": "QUAKEKIT_DISCORD_MENTION_ROLE",
      "help": "Role text included in announcement previews.",
      "group": "Stream",
      "order": 47,
      "uiControl": "textField"
    },
    {
      "id": "dry_run",
      "title": "Dry Run",
      "type": "boolean",
      "defaultValue": true,
      "environment": "QUAKEKIT_DISCORD_DRY_RUN",
      "help": "When true, post and presence actions return planned Discord calls only.",
      "group": "Safety",
      "order": 60,
      "uiControl": "toggle"
    }
  ],
  "actions": [
    {
      "id": "discord.postStatus",
      "title": "Post Status",
      "argumentSchema": [
        {
          "id": "message",
          "title": "Message",
          "type": "string",
          "required": false
        }
      ]
    },
    {
      "id": "discord.setPresence",
      "title": "Set Presence",
      "argumentSchema": [
        {
          "id": "state",
          "title": "State",
          "type": "string",
          "required": false
        }
      ]
    },
    {
      "id": "discord.openVoice",
      "title": "Open Voice",
      "argumentSchema": [
        {
          "id": "channel",
          "title": "Channel",
          "type": "string",
          "required": false,
          "defaultValue": "stream-room"
        }
      ]
    },
    {
      "id": "discord.announceStream",
      "title": "Announce Stream",
      "argumentSchema": [
        {
          "id": "title",
          "title": "Title",
          "type": "string",
          "required": false,
          "defaultValue": "Working session"
        },
        {
          "id": "url",
          "title": "URL",
          "type": "url",
          "required": false
        }
      ]
    },
    {
      "id": "discord.clearMentions",
      "title": "Clear Mentions",
      "argumentSchema": []
    }
  ],
  "dataStreams": [
    {
      "id": "discord.companion",
      "title": "Discord Companion",
      "valueSchema": [
        {
          "id": "guild",
          "title": "Guild",
          "type": "string",
          "required": false
        },
        {
          "id": "onlineMembers",
          "title": "Online Members",
          "type": "integer",
          "required": false
        },
        {
          "id": "presence",
          "title": "Presence",
          "type": "string",
          "required": false
        },
        {
          "id": "voiceMembers",
          "title": "Voice Members",
          "type": "integer",
          "required": false
        },
        {
          "id": "webhookConfigured",
          "title": "Webhook Configured",
          "type": "boolean",
          "required": false
        },
        {
          "id": "streamTitle",
          "title": "Stream Title",
          "type": "string",
          "required": false
        }
      ]
    }
  ],
  "views": [
    {
      "id": "discord.panel",
      "title": "Discord Companion",
      "type": "dataDriven",
      "presentation": "widget",
      "dataStreamID": "discord.companion",
      "columnSpan": 2,
      "rowSpan": 1,
      "preferredWidth": 480,
      "preferredHeight": 220
    }
  ]
}
