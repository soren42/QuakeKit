{
  "$schema": "../../../schemas/functional-plugin.schema.json",
  "id": "ai_agent",
  "name": "AI Command Center",
  "version": "1.0.0-rc1",
  "apiVersion": "0.1",
  "entry": {
    "transport": "stdioJSONRPC",
    "command": "ai-agent-adapter",
    "arguments": []
  },
  "capabilities": [
    "actionProvider",
    "dataProvider",
    "settings",
    "viewProvider",
    "eventSubscriber",
    "backgroundWorker"
  ],
  "permissions": [
    {
      "audioCapture": {}
    },
    {
      "audioPlayback": {}
    },
    {
      "localProcess": {}
    },
    {
      "filesystem": {
        "paths": [
          "~/Documents",
          "~/Desktop",
          "~/Downloads"
        ],
        "write": true
      }
    },
    {
      "network": {
        "hosts": [
          "api.openai.com",
          "api.anthropic.com",
          "generativelanguage.googleapis.com",
          "api.deepseek.com"
        ]
      }
    },
    {
      "secrets": {
        "keys": [
          "OPENAI_API_KEY",
          "ANTHROPIC_API_KEY",
          "GEMINI_API_KEY",
          "DEEPSEEK_API_KEY"
        ]
      }
    }
  ],
  "settings": [
    {
      "id": "harness",
      "title": "Agent / Harness",
      "type": "choice",
      "defaultValue": "codex",
      "choices": [
        "claude",
        "claude_code",
        "chatgpt",
        "codex",
        "gemini",
        "grok",
        "deepseek",
        "cursor",
        "antigravity",
        "local"
      ],
      "environment": "QUAKEKIT_AGENT_HARNESS",
      "help": "The active AI harness shown by the command center. QuakeKit uses official APIs or local tools only; it does not automate consumer web UIs."
    },
    {
      "id": "project_path",
      "title": "Project Path",
      "type": "string",
      "defaultValue": "",
      "environment": "QUAKEKIT_AGENT_PROJECT_PATH",
      "help": "Optional project path used for the active-session summary.",
      "group": "Session",
      "order": 5,
      "uiControl": "filePicker"
    },
    {
      "id": "transcription_backend",
      "title": "Transcription Backend",
      "type": "choice",
      "defaultValue": "wispr_flow",
      "choices": [
        "wispr_flow",
        "whisper_cli",
        "apple_speech",
        "openai_whisper",
        "manual_file"
      ],
      "environment": "QUAKEKIT_AGENT_TRANSCRIBE_BACKEND",
      "help": "Preferred transcription path. The stub only transcribes configured files through local whisper when available."
    },
    {
      "id": "audio_file",
      "title": "Audio File",
      "type": "string",
      "defaultValue": "",
      "environment": "QUAKEKIT_AGENT_AUDIO_FILE",
      "help": "Optional local audio file to transcribe for meeting/brainstorm summaries."
    },
    {
      "id": "summary_style",
      "title": "Summary Style",
      "type": "choice",
      "defaultValue": "meeting_notes",
      "choices": [
        "meeting_notes",
        "brainstorm",
        "action_items",
        "executive_summary"
      ],
      "environment": "QUAKEKIT_AGENT_SUMMARY_STYLE",
      "help": "Preferred structure for generated summaries."
    },
    {
      "id": "speaker_output",
      "title": "Speaker Output",
      "type": "boolean",
      "defaultValue": false,
      "environment": "QUAKEKIT_AGENT_SPEAKER_OUTPUT",
      "help": "Whether future adapters may use spoken responses."
    },
    {
      "id": "session_file",
      "title": "Session File",
      "type": "string",
      "defaultValue": "",
      "environment": "QUAKEKIT_AGENT_SESSION_FILE",
      "help": "Optional pipe-delimited file: project|agents|tokensUsed|tokensRemaining|limit|queue|status.",
      "group": "Session",
      "order": 60,
      "uiControl": "filePicker"
    }
  ],
  "actions": [
    {
      "id": "agent.listen",
      "title": "Start Listening",
      "argumentSchema": []
    },
    {
      "id": "agent.stop",
      "title": "Stop Listening",
      "argumentSchema": []
    },
    {
      "id": "agent.transcribe",
      "title": "Transcribe Audio",
      "argumentSchema": []
    },
    {
      "id": "agent.summarize",
      "title": "Summarize Session",
      "argumentSchema": []
    },
    {
      "id": "agent.speak",
      "title": "Speak Response",
      "argumentSchema": []
    }
  ],
  "dataStreams": [
    {
      "id": "agent.session",
      "title": "Agent Session",
      "valueSchema": [
        {
          "id": "sessionId",
          "title": "Session ID",
          "type": "string",
          "required": false
        },
        {
          "id": "captureState",
          "title": "Capture State",
          "type": "string",
          "required": false
        },
        {
          "id": "elapsedSeconds",
          "title": "Elapsed Seconds",
          "type": "integer",
          "required": false
        },
        {
          "id": "inputLevel",
          "title": "Input Level",
          "type": "number",
          "required": false
        },
        {
          "id": "summary",
          "title": "Summary",
          "type": "string",
          "required": false
        },
        {
          "id": "exportPath",
          "title": "Export Path",
          "type": "string",
          "required": false
        }
      ]
    }
  ],
  "views": [
    {
      "id": "agent.conversation",
      "title": "AI Command Center",
      "type": "webDocument",
      "presentation": "pageAndWidget",
      "entryPath": "index.html",
      "dataStreamID": "agent.session",
      "columnSpan": 3,
      "rowSpan": 2,
      "preferredWidth": 1920,
      "preferredHeight": 480,
      "icon": "sparkles"
    },
    {
      "id": "agent.session",
      "title": "AI Session",
      "type": "dataDriven",
      "presentation": "pageAndWidget",
      "dataStreamID": "agent.session",
      "columnSpan": 3,
      "rowSpan": 1,
      "preferredWidth": 960,
      "preferredHeight": 240,
      "icon": "sparkles"
    }
  ]
}
