#!/bin/sh
set -eu

request="$(cat)"
method="$(printf '%s' "$request" | sed -n 's/.*"method"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)"
harness="${QUAKEKIT_AGENT_HARNESS:-codex}"
backend="${QUAKEKIT_AGENT_TRANSCRIBE_BACKEND:-wispr_flow}"
audio_file="${QUAKEKIT_AGENT_AUDIO_FILE:-}"
summary_style="${QUAKEKIT_AGENT_SUMMARY_STYLE:-meeting_notes}"
speaker_output="${QUAKEKIT_AGENT_SPEAKER_OUTPUT:-false}"
project_path="${QUAKEKIT_AGENT_PROJECT_PATH:-}"
session_file="${QUAKEKIT_AGENT_SESSION_FILE:-}"

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g'
}

transcript="No transcript has been captured yet."
transcription_state="stub"
transcription_detail="Configure an audio file or connect a live recorder."
session_id="${QUAKEKIT_AGENT_SESSION_ID:-voice-demo}"
elapsed="${QUAKEKIT_AGENT_ELAPSED_SECONDS:-0}"
input_level="${QUAKEKIT_AGENT_INPUT_LEVEL:-0.18}"
agents="${QUAKEKIT_AGENT_AGENTS:-1}"
tokens_used="${QUAKEKIT_AGENT_TOKENS_USED:-0}"
tokens_remaining="${QUAKEKIT_AGENT_TOKENS_REMAINING:-0}"
queue_depth="${QUAKEKIT_AGENT_QUEUE_DEPTH:-0}"

if [ -n "$session_file" ] && [ -r "$session_file" ]; then
  first_line="$(sed -n '1p' "$session_file")"
  old_ifs=$IFS
  IFS='|'
  set -- $first_line
  IFS=$old_ifs
  project_path="${1:-$project_path}"
  agents="${2:-$agents}"
  tokens_used="${3:-$tokens_used}"
  tokens_remaining="${4:-$tokens_remaining}"
  queue_depth="${6:-$queue_depth}"
  state="${7:-ready}"
fi

if [ -n "$audio_file" ] && [ -f "$audio_file" ]; then
  if command -v whisper >/dev/null 2>&1; then
    text_file="$(mktemp -t quakekit-whisper).txt"
    if whisper "$audio_file" --model tiny --output_format txt --output_dir "$(dirname "$text_file")" >/dev/null 2>&1; then
      candidate="$(dirname "$text_file")/$(basename "$audio_file" | sed 's/\.[^.]*$//').txt"
      if [ -f "$candidate" ]; then
        transcript="$(sed -n '1,12p' "$candidate" | tr '\n' ' ')"
        transcription_state="transcribed"
        transcription_detail="local whisper"
      fi
    fi
    rm -f "$text_file"
  elif [ "$backend" = "wispr_flow" ]; then
    transcript="Wispr Flow is selected. Use the installed app to dictate into the active text destination; QuakeKit will consume saved text in a future bridge."
    transcription_state="external"
    transcription_detail="wispr flow selected"
  fi
fi

case "$method" in
  action.agent.listen)
    state="listening"
    ;;
  action.agent.stop)
    state="stopped"
    ;;
  action.agent.transcribe)
    state="$transcription_state"
    ;;
  action.agent.summarize)
    state="summarized"
    ;;
  action.agent.speak)
    state="speaker ${speaker_output}"
    ;;
  *)
    state="${state:-ready}"
    ;;
esac

printf '{"ok":true,"adapter":"ai-agent-adapter","mode":"offline-safe","sessionId":"%s","status":"%s","captureState":"%s","elapsedSeconds":%s,"inputLevel":%s,"harness":"%s","project":"%s","agents":%s,"tokensUsed":%s,"tokensRemaining":%s,"queueDepth":%s,"backend":"%s","summaryStyle":"%s","speakerOutput":%s,"transcriptSegments":[{"speaker":"User","text":"Capture the idea and turn it into next steps."},{"speaker":"Agent","text":"Ready to summarize once a transcript is available."}],"summary":"AI Command Center is ready for microphone, transcription, summary, and speaker-output UI states.","actionItems":[{"title":"Request microphone permission","state":"available"},{"title":"Record 30 second clip","state":"available"},{"title":"Summarize transcript","state":"planned"}],"decisions":["Use local or official API transcription boundary","Do not scrape consumer LLM UIs"],"speakerQueue":[{"text":"QuakeKit voice output is ready.","state":"queued"}],"exportPath":"~/Library/Application Support/QuakeKit/Recordings/","actions":[{"id":"agent.listen","enabled":true,"dryRun":true},{"id":"agent.stop","enabled":true,"dryRun":true},{"id":"agent.transcribe","enabled":true,"dryRun":true},{"id":"agent.summarize","enabled":true,"dryRun":true},{"id":"agent.speak","enabled":true,"dryRun":true}],"rows":[{"title":"Harness","value":"%s","detail":"official API/local endpoint only"},{"title":"Project","value":"%s","detail":"active workspace"},{"title":"Agents","value":"%s","detail":"active agents"},{"title":"Tokens","value":"%s used","detail":"%s remaining"},{"title":"Capture","value":"%s","detail":"%ss · input %.2f"},{"title":"Transcription","value":"%s","detail":"%s"},{"title":"Summary","value":"%s","detail":"meeting and brainstorming notes"},{"title":"Transcript","value":"Ready","detail":"%s"}],"source":"ai-agent-adapter"}\n' \
  "$(json_escape "$session_id")" "$(json_escape "$state")" "$(json_escape "$state")" "$elapsed" "$input_level" "$(json_escape "$harness")" "$(json_escape "$project_path")" "$agents" "$tokens_used" "$tokens_remaining" "$queue_depth" "$(json_escape "$backend")" "$(json_escape "$summary_style")" "$speaker_output" \
  "$(json_escape "$harness")" "$(json_escape "${project_path:-No project selected}")" "$agents" "$tokens_used" "$tokens_remaining" "$(json_escape "$state")" "$elapsed" "$input_level" "$(json_escape "$backend")" "$(json_escape "$transcription_detail")" "$(json_escape "$summary_style")" "$(json_escape "$transcript")"
