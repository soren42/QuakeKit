{
  "$schema": "../../../schemas/functional-plugin.schema.json",
  "id": "markets",
  "name": "Markets",
  "version": "0.1.0",
  "apiVersion": "0.1",
  "entry": {
    "transport": "php",
    "command": "markets.php",
    "arguments": []
  },
  "capabilities": [
    "dataProvider",
    "viewProvider"
  ],
  "permissions": [
    {
      "network": {
        "hosts": [
          "query1.finance.yahoo.com"
        ]
      }
    }
  ],
  "actions": [
    {
      "id": "markets.refresh",
      "title": "Refresh Watchlist",
      "argumentSchema": []
    }
  ],
  "dataStreams": [
    {
      "id": "markets.watchlist",
      "title": "Watchlist",
      "valueSchema": []
    }
  ],
  "views": [
    {
      "id": "markets.ticker",
      "title": "Market Ticker",
      "type": "dataDriven",
      "presentation": "widget",
      "dataStreamID": "markets.watchlist",
      "columnSpan": 2,
      "rowSpan": 1,
      "preferredWidth": 480,
      "preferredHeight": 200
    }
  ]
}
