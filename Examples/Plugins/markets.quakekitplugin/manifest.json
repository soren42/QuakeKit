{
  "$schema": "../../../schemas/functional-plugin.schema.json",
  "id": "markets",
  "name": "Markets",
  "version": "0.1.0",
  "apiVersion": "0.1",
  "entry": {
    "transport": "php",
    "command": "markets.php",
    "arguments": []
  },
  "capabilities": [
    "dataProvider",
    "settings",
    "viewProvider"
  ],
  "permissions": [
    {
      "network": {
        "hosts": [
          "query1.finance.yahoo.com"
        ]
      }
    }
  ],
  "settings": [
    {
      "id": "watchlist",
      "title": "Watchlist",
      "type": "choice",
      "defaultValue": "AAPL,NVDA,MSFT",
      "choices": [
        "AAPL,NVDA,MSFT",
        "SPY,QQQ,DIA",
        "TSLA,AMD,INTC",
        "BTC-USD,ETH-USD,SOL-USD"
      ],
      "environment": "QUAKEKIT_MARKET_SYMBOLS",
      "help": "Comma-separated ticker preset for the market data provider."
    }
  ],
  "actions": [
    {
      "id": "markets.refresh",
      "title": "Refresh Watchlist",
      "argumentSchema": []
    }
  ],
  "dataStreams": [
    {
      "id": "markets.watchlist",
      "title": "Watchlist",
      "valueSchema": []
    }
  ],
  "views": [
    {
      "id": "markets.ticker",
      "title": "Market Ticker",
      "type": "dataDriven",
      "presentation": "widget",
      "dataStreamID": "markets.watchlist",
      "columnSpan": 2,
      "rowSpan": 1,
      "preferredWidth": 480,
      "preferredHeight": 200
    }
  ]
}
