{
  "$schema": "../../../schemas/functional-plugin.schema.json",
  "id": "system_monitor",
  "name": "System Monitor",
  "version": "0.1.0",
  "apiVersion": "0.1",
  "entry": {
    "transport": "shell",
    "command": "system-monitor.sh",
    "arguments": []
  },
  "capabilities": [
    "dataProvider",
    "settings",
    "viewProvider",
    "backgroundWorker"
  ],
  "permissions": [
    {
      "localProcess": {}
    }
  ],
  "settings": [
    {
      "id": "refresh_interval",
      "title": "Refresh Interval",
      "type": "choice",
      "defaultValue": 5,
      "choices": [
        2,
        5,
        10,
        30
      ],
      "environment": "QUAKEKIT_SYSTEM_REFRESH_SECONDS",
      "help": "Preferred refresh cadence in seconds for hosts that run background streams."
    },
    {
      "id": "detail_level",
      "title": "Detail Level",
      "type": "choice",
      "defaultValue": "balanced",
      "choices": [
        "minimal",
        "balanced",
        "verbose"
      ],
      "environment": "QUAKEKIT_SYSTEM_DETAIL_LEVEL",
      "help": "Controls how much system detail the plugin returns."
    }
  ],
  "actions": [
    {
      "id": "system.refresh",
      "title": "Refresh Metrics",
      "argumentSchema": []
    }
  ],
  "dataStreams": [
    {
      "id": "system.metrics",
      "title": "System Metrics",
      "valueSchema": [
        {
          "id": "cpu",
          "title": "CPU",
          "type": "number",
          "required": false
        },
        {
          "id": "memory",
          "title": "Memory",
          "type": "number",
          "required": false
        },
        {
          "id": "disk",
          "title": "Disk",
          "type": "number",
          "required": false
        },
        {
          "id": "battery",
          "title": "Battery",
          "type": "number",
          "required": false
        },
        {
          "id": "threads",
          "title": "Threads",
          "type": "integer",
          "required": false
        },
        {
          "id": "processes",
          "title": "Processes",
          "type": "integer",
          "required": false
        },
        {
          "id": "networkInGB",
          "title": "Network In",
          "type": "number",
          "required": false
        },
        {
          "id": "networkOutGB",
          "title": "Network Out",
          "type": "number",
          "required": false
        }
      ]
    }
  ],
  "views": [
    {
      "id": "system.overview",
      "title": "System Overview",
      "type": "dataDriven",
      "presentation": "pageAndWidget",
      "layout": "fullScreen",
      "dataStreamID": "system.metrics",
      "columnSpan": 4,
      "rowSpan": 2,
      "preferredWidth": 1920,
      "preferredHeight": 480
    }
  ]
}
