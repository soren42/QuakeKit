{
  "$schema": "../../../schemas/functional-plugin.schema.json",
  "id": "system_monitor",
  "name": "System Monitor",
  "version": "0.1.0",
  "apiVersion": "0.1",
  "entry": {
    "transport": "shell",
    "command": "system-monitor.sh",
    "arguments": []
  },
  "capabilities": [
    "dataProvider",
    "viewProvider",
    "backgroundWorker"
  ],
  "permissions": [
    {
      "localProcess": {}
    }
  ],
  "actions": [
    {
      "id": "system.refresh",
      "title": "Refresh Metrics",
      "argumentSchema": []
    }
  ],
  "dataStreams": [
    {
      "id": "system.metrics",
      "title": "System Metrics",
      "valueSchema": [
        {
          "id": "cpu",
          "title": "CPU",
          "type": "number",
          "required": false
        },
        {
          "id": "memory",
          "title": "Memory",
          "type": "number",
          "required": false
        }
      ]
    }
  ],
  "views": [
    {
      "id": "system.overview",
      "title": "System Overview",
      "type": "dataDriven",
      "presentation": "pageAndWidget",
      "dataStreamID": "system.metrics",
      "columnSpan": 2,
      "rowSpan": 1,
      "preferredWidth": 480,
      "preferredHeight": 200
    }
  ]
}
