{
  "$schema": "../../../schemas/functional-plugin.schema.json",
  "id": "home_assistant",
  "name": "Home Assistant",
  "version": "0.1.0",
  "apiVersion": "0.1",
  "entry": {
    "transport": "shell",
    "command": "home-assistant.sh",
    "arguments": []
  },
  "capabilities": [
    "actionProvider",
    "dataProvider",
    "settings",
    "viewProvider",
    "deviceProvider"
  ],
  "permissions": [
    {
      "network": {
        "hosts": [
          "homeassistant.local",
          "localhost"
        ]
      }
    },
    {
      "secrets": {
        "keys": [
          "HOME_ASSISTANT_TOKEN"
        ]
      }
    }
  ],
  "settings": [
    {
      "id": "base_url",
      "title": "Base URL",
      "type": "string",
      "defaultValue": "http://homeassistant.local:8123",
      "environment": "QUAKEKIT_HOME_ASSISTANT_URL",
      "help": "Home Assistant base URL used by real adapters.",
      "group": "Connection",
      "order": 10,
      "uiControl": "textField"
    },
    {
      "id": "dashboard_area",
      "title": "Dashboard Area",
      "type": "choice",
      "defaultValue": "Living Room",
      "choices": [
        "Living Room",
        "Kitchen",
        "Office",
        "Garage"
      ],
      "environment": "QUAKEKIT_HOME_ASSISTANT_AREA",
      "help": "Area summarized by the example dashboard.",
      "group": "Dashboard",
      "order": 20,
      "uiControl": "segmented"
    },
    {
      "id": "scene_profile",
      "title": "Scene Profile",
      "type": "choice",
      "defaultValue": "evening",
      "choices": [
        "morning",
        "workday",
        "evening",
        "away"
      ],
      "environment": "QUAKEKIT_HOME_ASSISTANT_SCENE_PROFILE",
      "help": "Scene set highlighted by quick scene controls.",
      "group": "Scenes",
      "order": 30,
      "uiControl": "popup"
    },
    {
      "id": "favorite_scene",
      "title": "Favorite Scene",
      "type": "string",
      "defaultValue": "scene.living_room_evening",
      "environment": "QUAKEKIT_HOME_ASSISTANT_FAVORITE_SCENE",
      "help": "Default scene used by Run Scene when no argument is supplied.",
      "group": "Scenes",
      "order": 40,
      "uiControl": "textField"
    },
    {
      "id": "include_climate",
      "title": "Include Climate",
      "type": "boolean",
      "defaultValue": true,
      "environment": "QUAKEKIT_HOME_ASSISTANT_INCLUDE_CLIMATE",
      "help": "Shows climate entities in the deterministic response.",
      "group": "Dashboard",
      "order": 50,
      "uiControl": "toggle"
    },
    {
      "id": "security_mode",
      "title": "Security Mode",
      "type": "choice",
      "defaultValue": "home",
      "choices": [
        "disarmed",
        "home",
        "away",
        "night"
      ],
      "environment": "QUAKEKIT_HOME_ASSISTANT_SECURITY_MODE",
      "help": "Alarm panel mode shown by the offline-safe security card.",
      "group": "Security",
      "order": 60,
      "uiControl": "segmented"
    },
    {
      "id": "dry_run",
      "title": "Dry Run",
      "type": "boolean",
      "defaultValue": true,
      "environment": "QUAKEKIT_HOME_ASSISTANT_DRY_RUN",
      "help": "When true, service calls return local request plans only.",
      "group": "Safety",
      "order": 70,
      "uiControl": "toggle"
    }
  ],
  "actions": [
    {
      "id": "homeassistant.refresh",
      "title": "Refresh Dashboard",
      "argumentSchema": []
    },
    {
      "id": "homeassistant.toggleEntity",
      "title": "Toggle Entity",
      "argumentSchema": [
        {
          "id": "entity_id",
          "title": "Entity ID",
          "type": "string",
          "required": false
        }
      ]
    },
    {
      "id": "homeassistant.runScene",
      "title": "Run Scene",
      "argumentSchema": [
        {
          "id": "scene_id",
          "title": "Scene ID",
          "type": "string",
          "required": false
        }
      ]
    },
    {
      "id": "homeassistant.setClimate",
      "title": "Set Climate",
      "argumentSchema": [
        {
          "id": "entity_id",
          "title": "Entity ID",
          "type": "string",
          "required": false,
          "defaultValue": "climate.main_floor"
        },
        {
          "id": "temperature",
          "title": "Temperature",
          "type": "number",
          "required": false,
          "defaultValue": 72
        }
      ]
    },
    {
      "id": "homeassistant.armSecurity",
      "title": "Arm Security",
      "argumentSchema": [
        {
          "id": "mode",
          "title": "Mode",
          "type": "string",
          "required": false,
          "defaultValue": "home"
        }
      ]
    }
  ],
  "dataStreams": [
    {
      "id": "homeassistant.area",
      "title": "Area Summary",
      "valueSchema": [
        {
          "id": "area",
          "title": "Area",
          "type": "string",
          "required": false
        },
        {
          "id": "lightsOn",
          "title": "Lights On",
          "type": "integer",
          "required": false
        },
        {
          "id": "temperature",
          "title": "Temperature",
          "type": "number",
          "required": false
        },
        {
          "id": "sceneProfile",
          "title": "Scene Profile",
          "type": "string",
          "required": false
        },
        {
          "id": "securityMode",
          "title": "Security Mode",
          "type": "string",
          "required": false
        }
      ]
    }
  ],
  "views": [
    {
      "id": "homeassistant.dashboard",
      "title": "Home Dashboard",
      "type": "dataDriven",
      "presentation": "pageAndWidget",
      "layout": "grid",
      "dataStreamID": "homeassistant.area",
      "columnSpan": 2,
      "rowSpan": 2,
      "preferredWidth": 520,
      "preferredHeight": 360
    }
  ]
}
