{
  "$schema": "../../../schemas/functional-plugin.schema.json",
  "id": "sports_scores",
  "name": "Sports Scores",
  "version": "0.1.0",
  "apiVersion": "0.1",
  "entry": {
    "transport": "stdioJSONRPC",
    "command": "sports-scores",
    "arguments": []
  },
  "capabilities": [
    "dataProvider",
    "settings",
    "viewProvider"
  ],
  "permissions": [
    {
      "network": {
        "hosts": [
          "site.api.espn.com"
        ]
      }
    }
  ],
  "settings": [
    {
      "id": "league",
      "title": "League",
      "type": "choice",
      "defaultValue": "mlb",
      "choices": [
        "mlb",
        "nba",
        "nfl",
        "nhl"
      ],
      "environment": "QUAKEKIT_SPORTS_LEAGUE",
      "help": "League used by the scoreboard provider."
    }
  ],
  "actions": [
    {
      "id": "sports.refresh",
      "title": "Refresh Scores",
      "argumentSchema": []
    }
  ],
  "dataStreams": [
    {
      "id": "sports.favoriteTeams",
      "title": "Favorite Teams",
      "valueSchema": []
    }
  ],
  "views": [
    {
      "id": "sports.scoreboard",
      "title": "Scoreboard",
      "type": "dataDriven",
      "presentation": "pageAndWidget",
      "dataStreamID": "sports.favoriteTeams",
      "columnSpan": 2,
      "rowSpan": 1,
      "preferredWidth": 480,
      "preferredHeight": 200
    }
  ]
}
