{
  "$schema": "../../../schemas/functional-plugin.schema.json",
  "id": "sports_scores",
  "name": "Sports Scores",
  "version": "0.1.0",
  "apiVersion": "0.1",
  "entry": {
    "transport": "stdioJSONRPC",
    "command": "sports-scores",
    "arguments": []
  },
  "capabilities": [
    "dataProvider",
    "settings",
    "viewProvider"
  ],
  "permissions": [
    {
      "network": {
        "hosts": [
          "site.api.espn.com"
        ]
      }
    }
  ],
  "settings": [
    {
      "id": "league",
      "title": "League",
      "type": "choice",
      "defaultValue": "mlb",
      "choices": [
        "mlb",
        "nba",
        "nfl",
        "nhl"
      ],
      "environment": "QUAKEKIT_SPORTS_LEAGUE",
      "help": "League used by the scoreboard provider."
    },
    {
      "id": "favorite_team",
      "title": "Favorite Team",
      "type": "choice",
      "defaultValue": "CAR",
      "choices": [
        "CAR",
        "ATL",
        "NYM",
        "LAL",
        "GSW",
        "NYR"
      ],
      "environment": "QUAKEKIT_SPORTS_FAVORITE_TEAM",
      "help": "Preferred team abbreviation highlighted by future score renderers."
    }
  ],
  "actions": [
    {
      "id": "sports.refresh",
      "title": "Refresh Scores",
      "argumentSchema": []
    }
  ],
  "dataStreams": [
    {
      "id": "sports.favoriteTeams",
      "title": "Favorite Teams",
      "valueSchema": [
        {
          "id": "games",
          "title": "Games",
          "type": "string",
          "required": false
        },
        {
          "id": "homeTeam",
          "title": "Home Team",
          "type": "string",
          "required": false
        },
        {
          "id": "awayTeam",
          "title": "Away Team",
          "type": "string",
          "required": false
        },
        {
          "id": "homeScore",
          "title": "Home Score",
          "type": "integer",
          "required": false
        },
        {
          "id": "awayScore",
          "title": "Away Score",
          "type": "integer",
          "required": false
        },
        {
          "id": "status",
          "title": "Status",
          "type": "string",
          "required": false
        },
        {
          "id": "favorite",
          "title": "Favorite",
          "type": "string",
          "required": false
        }
      ]
    }
  ],
  "views": [
    {
      "id": "sports.scoreboard",
      "title": "Scoreboard",
      "type": "dataDriven",
      "presentation": "pageAndWidget",
      "dataStreamID": "sports.favoriteTeams",
      "columnSpan": 3,
      "rowSpan": 1,
      "preferredWidth": 960,
      "preferredHeight": 240
    }
  ]
}
